<header role="banner" class="site-header">
  <div class="container-global mx-auto w-100">
    <div class="row align-middle">
      <div class="col-xs-6 col-md-3 is-flex">
        <a class="link logo simple" href="/" aria-label="{{ global.empresa }} — Volver al inicio">
          <div class="is-flex">
            <div class="mr-16 mt-16 mb-16">
              <img width="180" height="48" src="{{ global.logo }}" alt="Logotipo {{ global.empresa }}" loading="eager" decoding="async" fetchpriority="high">
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-9 hidden-xs hidden-sm text-right is-flex align-multi-center content-end">
        <nav role="navigation" aria-label="Menú principal" class="menu menu-desktop-wrap">
