    <script defer src="/assets/js/inview.js"></script>

    <script>
      document.addEventListener('click',function(e){
        var a=e.target.closest('a');if(!a)return;
        var ev=null,p={};
        if(a.href.indexOf('tel:')===0){ev='lead_phone_click';p={phone:a.href.replace('tel:','')};}
        else if(a.href.indexOf('wa.me')!==-1||a.href.indexOf('whatsapp')!==-1){ev='lead_whatsapp_click';}
        else if(a.matches('[data-cta]')){ev='cta_click';p={label:a.dataset.cta};}
        if(ev&&window.dataLayer){dataLayer.push(Object.assign({event:ev},p));}
      });
      document.addEventListener('submit',function(e){
        var f=e.target;if(!f||f.tagName!=='FORM')return;
        if(window.dataLayer){dataLayer.push({event:'lead_form_submit',form_id:f.getAttribute('name')||'unknown'});}
      });
    </script>
  </body>
