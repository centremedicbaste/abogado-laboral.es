---
layout: layout/base.njk
---
{# ============================================================
   BLOGPOST — Alineado con el sistema Lex del resto del sitio
   - Hero compacto (lex-hero-page) con eyebrow + título + lead + meta
   - Imagen featured opcional (mismo estilo que media de lex-blog)
   - Body 2 columnas: TOC sticky + cuerpo (patrón de _servicio.njk)
   - Related posts con lex-blog__grid
   - CTA final reutilizando lex-cta-final.njk
   ============================================================ #}

<article class="lex-post">

  {# ── HERO (estilo lex-hero-page) ────────────────────────── #}
  <section class="lex-hero-page lex-post__hero">
    <div class="container-global mx-auto lex-hero-page__wrap">
      <nav class="lex-crumbs" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        {% if tags and tags.length > 1 %}
          <span aria-hidden="true">/</span>
          <a href="/blog/">{{ tags[1] | capitalize }}</a>
        {% endif %}
      </nav>

      {% if tags and tags.length > 1 %}
      <p class="lex-eyebrow lex-eyebrow--bar">
        <span class="lex-eyebrow__bar" aria-hidden="true"></span>
        {{ tags[1] | capitalize }}
      </p>
      {% endif %}

      <h1 class="lex-hero-page__title">{{ title }}</h1>

      {% if subtitle %}
      <p class="lex-hero-page__lead">{{ subtitle }}</p>
      {% endif %}

      <div class="lex-post__meta">
        {% if fecha %}
        <span class="lex-post__meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          {{ fecha }}
        </span>
        {% endif %}
        <span class="lex-post__meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/></svg>
          {{ global.author or "Equipo Abogado Laboral" }}
        </span>
        <span class="lex-post__meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          Lectura · {{ reading_time or "8 min" }}
        </span>
      </div>
    </div>
  </section>

  {# ── IMAGEN FEATURED (opcional) ─────────────────────────── #}
  {% if image and not noheroimage %}
  <div class="container-global mx-auto lex-post__cover-wrap">
    <div class="lex-post__cover">
      <img src="{{ image }}" alt="{{ imageAlt or title }}" width="1200" height="675" loading="eager" decoding="async"/>
      <span class="lex-post__cover-dot" aria-hidden="true"></span>
    </div>
  </div>
  {% endif %}

  {# ── BODY 2 COLUMNAS (TOC sticky + contenido) ───────────── #}
  <section class="lex-post__main">
    <div class="container-global mx-auto">
      <div class="lex-post__grid">

        <aside class="lex-post__aside" aria-label="Índice y contacto">
          <div class="lex-post__aside-sticky">
            <div class="lex-post__toc">
              <p class="lex-eyebrow lex-eyebrow--bar">
                <span class="lex-eyebrow__bar" aria-hidden="true"></span>
                En este artículo
              </p>
              <div class="lex-post__toc-content">
                {{ content | toc | safe }}
              </div>
            </div>

            <div class="lex-post__aside-cta">
              <p class="lex-eyebrow lex-eyebrow--light lex-eyebrow--bar">
                <span class="lex-eyebrow__bar" aria-hidden="true"></span>
                Habla con nosotros
              </p>
              <h3 class="lex-post__aside-cta-title">¿Necesitas ayuda con tu caso?</h3>
              <p class="lex-post__aside-cta-text">Estudio gratuito de tu caso. Atención presencial en Sevilla y videoconsulta en toda España.</p>
              <a class="lex-btn lex-btn--accent lex-btn--full" href="/contacto/" data-cta="post_aside_consulta">Reservar consulta</a>
              <a class="lex-btn lex-btn--ghost lex-btn--full lex-post__aside-tel" href="tel:{{ global.telefono_e164 }}" data-cta="post_aside_tel">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" aria-hidden="true"><path d="M5 4 H9 L11 9 L8 11 C9 14 10 15 13 16 L15 13 L20 15 V19 C20 20 19 21 18 21 C10 21 3 14 3 6 C3 5 4 4 5 4 Z"/></svg>
                {{ global.telefono }}
              </a>
            </div>
          </div>
        </aside>

        <div class="lex-post__body">
          {{ content | safe }}

          <hr class="lex-post__body-hr"/>
          <p class="lex-post__body-update">
            Última actualización: {{ fecha or "abril de 2026" }}. Este artículo refleja la doctrina y normativa vigente a la fecha. Si tu caso es urgente, llámanos: los plazos no esperan.
          </p>
        </div>

      </div>
    </div>
  </section>

  {# ── RELATED POSTS (lex-blog grid) ──────────────────────── #}
  {% if collections.post and collections.post.length > 1 %}
  <section class="lex-section lex-post__related">
    <div class="container-global mx-auto">
      <div class="lex-section__head">
        <div>
          <p class="lex-eyebrow lex-eyebrow--bar">
            <span class="lex-eyebrow__bar" aria-hidden="true"></span>
            Sigue leyendo
          </p>
          <h2 class="lex-section__title">Otros artículos del despacho</h2>
        </div>
        <a href="/blog/" class="lex-link">Ver todos los artículos →</a>
      </div>
      <div class="lex-blog__grid">
        {% set shown = 0 %}
        {% for p in collections.post | reverse %}
          {% if p.url != page.url and shown < 3 %}
            {% set shown = shown + 1 %}
            <article class="lex-blog__card">
              <a href="{{ p.url }}" class="lex-blog__card-link">
                <div class="lex-blog__card-media">
                  {% if p.data.image %}
                  <img src="{{ p.data.image }}" alt="{{ p.data.imageAlt or p.data.title }}" loading="lazy" decoding="async" width="600" height="338"/>
                  {% else %}
                  <span class="lex-blog__card-label">// portada</span>
                  {% endif %}
                  <span class="lex-blog__card-dot" aria-hidden="true"></span>
                </div>
                {% if p.data.tags and p.data.tags.length > 1 %}
                <span class="lex-pill lex-pill--small">{{ p.data.tags[1] | capitalize }}</span>
                {% endif %}
                <h3 class="lex-blog__card-title">{{ p.data.title }}</h3>
                {% if p.data.fecha %}<div class="lex-blog__card-meta">{{ p.data.fecha }}</div>{% endif %}
              </a>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {# ── CTA FINAL (reutiliza el include compartido) ───────── #}
  {% include "templates/lex-cta-final.njk" %}

</article>

{% include "templates/lex-styles.njk" %}

<style>
/* ============================================================
   POST · estilos específicos sobre el sistema Lex
   Tokens compartidos via :root (--c-primary, --c-accent...)
   ============================================================ */
.lex-post{
  --lp-ink: var(--c-primary, #0b1e4f);
  --lp-ink2: #1f2a44;
  --lp-accent: var(--c-accent, #2563eb);
  --lp-muted: #5b6b8f;
  --lp-line: #e3e8f3;
  --lp-soft: var(--bg-light, #f5f7fc);
  background:#fff;color:var(--lp-ink2);font-family:var(--font-sans);
}

/* ── HERO meta (debajo del lead) ── */
.lex-post__hero .lex-hero-page__wrap{padding-bottom:clamp(32px, 5vw, 56px);}
.lex-post__meta{
  display:flex;align-items:center;gap:24px;flex-wrap:wrap;
  margin-top:32px;padding-top:24px;border-top:1px solid var(--lp-line);
  font-family:var(--font-sans);font-size:14px;color:var(--lp-muted);
}
.lex-post__meta-item{display:inline-flex;align-items:center;gap:8px;}
.lex-post__meta-item svg{color:var(--lp-accent);}

/* ── IMAGEN FEATURED ── */
.lex-post__cover-wrap{padding:0;}
.lex-post__cover{
  position:relative;aspect-ratio:16/9;border-radius:18px;overflow:hidden;
  background:#e6ecf7;border:1px solid #d6deef;
  margin:clamp(24px,4vw,40px) auto 0;max-width:1100px;
}
.lex-post__cover img{width:100%;height:100%;object-fit:cover;display:block;}
.lex-post__cover-dot{
  position:absolute;right:14px;top:14px;
  width:10px;height:10px;border-radius:999px;background:var(--lp-accent);
}

/* ── MAIN GRID 2 COLUMNAS ── */
.lex-post__main{padding:clamp(56px, 8vw, 96px) 0;}
.lex-post__grid{display:grid;grid-template-columns:1fr;gap:48px;}
@media(min-width:992px){
  .lex-post__grid{grid-template-columns:280px minmax(0,1fr);gap:72px;}
}

/* ── ASIDE: TOC + CTA sticky ── */
.lex-post__aside{order:2;}
@media(min-width:992px){.lex-post__aside{order:1;}}
.lex-post__aside-sticky{position:sticky;top:96px;display:flex;flex-direction:column;gap:20px;}

.lex-post__toc{
  background:var(--lp-soft);border:1px solid var(--lp-line);
  border-radius:14px;padding:22px 22px 24px;
}
.lex-post__toc-content{margin-top:14px;}
.lex-post__toc-content nav,
.lex-post__toc-content > ul,
.lex-post__toc-content .toc{font-family:var(--font-sans);}
.lex-post__toc-content ul{list-style:none;padding:0;margin:0;}
.lex-post__toc-content ul ul{padding-left:0;margin-top:4px;}
.lex-post__toc-content li{margin:0;}
.lex-post__toc-content a{
  color:var(--lp-muted);text-decoration:none;display:block;
  font-size:14px;line-height:1.5;
  padding:6px 0 6px 14px;border-left:2px solid var(--lp-line);
  transition:color .15s ease, border-color .15s ease;
}
.lex-post__toc-content a:hover,
.lex-post__toc-content a.active{
  color:var(--lp-ink);border-color:var(--lp-accent);opacity:1;
}

.lex-post__aside-cta{
  background:var(--lp-ink);color:#dde4f5;
  border-radius:14px;padding:24px 22px;
}
.lex-post__aside-cta-title{
  font-family:var(--font-display);font-weight:500;
  font-size:22px;line-height:1.2;color:#fff;
  margin:10px 0 8px;letter-spacing:-0.012em;
}
.lex-post__aside-cta-text{
  font-family:var(--font-sans);font-size:14px;line-height:1.55;
  color:#b8c3e0;margin:0 0 18px;
}
.lex-post__aside-cta .lex-btn{margin-bottom:10px;}
.lex-post__aside-cta .lex-btn:last-child{margin-bottom:0;}
.lex-post__aside-cta .lex-btn--accent{background:var(--lp-accent);color:#fff;}
.lex-post__aside-cta .lex-btn--accent:hover{background:#1d4ed8;color:#fff;opacity:1;}
.lex-post__aside-cta .lex-btn--ghost{
  background:transparent;color:#fff;border:1px solid rgba(255,255,255,.3);
}
.lex-post__aside-cta .lex-btn--ghost:hover{
  background:rgba(255,255,255,.08);color:#fff;border-color:#fff;opacity:1;
}
.lex-post__aside-tel{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-size:14px;}

/* ── BODY del artículo ── */
.lex-post__body{
  order:1;
  font-family:var(--font-sans);
  font-size:18px;line-height:1.78;color:#2a3656;max-width:760px;
}
@media(min-width:992px){.lex-post__body{order:2;}}

.lex-post__body > p:first-of-type{
  font-size:21px;line-height:1.6;color:var(--lp-ink);margin-bottom:32px;
}
.lex-post__body p{margin:0 0 1.4em;}
.lex-post__body strong{color:var(--lp-ink);font-weight:600;}
.lex-post__body em{color:var(--lp-accent);font-style:italic;font-family:var(--font-display);font-weight:500;}

.lex-post__body a:not(.lex-btn){
  color:var(--lp-accent);text-decoration:underline;
  text-underline-offset:3px;text-decoration-thickness:1px;
  transition:color .15s ease;
}
.lex-post__body a:not(.lex-btn):hover{color:var(--lp-ink);opacity:1;}

.lex-post__body h2{
  font-family:var(--font-display);font-weight:500;letter-spacing:-0.022em;
  font-size:clamp(28px,3.4vw,38px);line-height:1.15;color:var(--lp-ink);
  margin:2.4em 0 .6em;padding-top:.6em;border-top:1px solid var(--lp-line);
}
.lex-post__body h2:first-child{border-top:0;padding-top:0;margin-top:0;}
.lex-post__body h3{
  font-family:var(--font-display);font-weight:500;letter-spacing:-0.012em;
  font-size:clamp(22px,2.4vw,28px);line-height:1.2;color:var(--lp-ink);
  margin:1.8em 0 .5em;
}
.lex-post__body h4{
  font-family:var(--font-sans);font-size:18px;font-weight:600;
  margin:1.6em 0 .4em;color:var(--lp-ink);
}
.lex-post__body ul,
.lex-post__body ol{padding-left:1.4em;margin:0 0 1.4em;}
.lex-post__body li{margin-bottom:.6em;line-height:1.7;}
.lex-post__body ul li::marker{color:var(--lp-accent);}
.lex-post__body ol li::marker{color:var(--lp-accent);font-weight:600;}

.lex-post__body blockquote{
  margin:2em 0;padding:24px 28px;
  border-left:3px solid var(--lp-accent);
  background:var(--lp-soft);border-radius:0 12px 12px 0;
  font-family:var(--font-display);font-style:italic;
  font-size:clamp(20px,2.2vw,24px);line-height:1.45;color:var(--lp-ink);
}
.lex-post__body blockquote p{margin:0;font-family:inherit;font-size:inherit;line-height:inherit;}

.lex-post__body table{
  width:100%;border-collapse:collapse;margin:2em 0;font-size:15px;
  border:1px solid var(--lp-line);border-radius:12px;overflow:hidden;
}
.lex-post__body thead th{
  background:var(--lp-ink);color:#fff;text-align:left;
  padding:14px 16px;font-weight:600;font-size:12px;
  text-transform:uppercase;letter-spacing:.12em;
}
.lex-post__body tbody td{padding:13px 16px;border-top:1px solid var(--lp-line);vertical-align:top;}
.lex-post__body tbody tr:nth-child(even){background:var(--lp-soft);}

.lex-post__body code{
  background:var(--lp-soft);color:var(--lp-ink);
  padding:2px 6px;border-radius:4px;font-size:.92em;
  font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
  border:1px solid var(--lp-line);
}
.lex-post__body pre{
  background:var(--lp-ink);color:#dde4f5;
  padding:18px 20px;border-radius:12px;overflow-x:auto;font-size:14px;
}
.lex-post__body pre code{background:none;padding:0;color:inherit;border:0;}
.lex-post__body img{max-width:100%;height:auto;border-radius:12px;margin:2em 0;border:1px solid var(--lp-line);}
.lex-post__body hr{border:0;border-top:1px solid var(--lp-line);margin:2.5em 0;}

/* anchor-link (markdown-it-anchor): mantenerlo discreto */
.lex-post__body .anchor-link{
  opacity:0;margin-right:.35em;text-decoration:none;
  color:var(--lp-muted);font-weight:400;transition:opacity .15s;
}
.lex-post__body h2:hover .anchor-link,
.lex-post__body h3:hover .anchor-link,
.lex-post__body h4:hover .anchor-link{opacity:.5;}

.lex-post__body-hr{border:0;border-top:1px solid var(--lp-line);margin:48px 0 24px;}
.lex-post__body-update{font-size:14px;color:var(--lp-muted);font-style:italic;margin:0;}

/* ── RELATED ── */
.lex-post__related{background:var(--lp-soft);border-top:1px solid var(--lp-line);}
</style>
