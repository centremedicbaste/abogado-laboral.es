<!-- seo_block.njk -->
{# Bloque de texto SEO denso en keywords — replica del bloque "Servicios del Derecho Laboral" del competidor.
   Diseñado para H2 con keyword principal + 3 párrafos largos + 4 sub-bloques con H4 keyword-rich. #}
<section class="bg-color ptr-64 pbr-64" aria-label="Servicios de derecho laboral">
  <div class="container-global">

    <div class="row align-middle pbr-48">
      <div class="col-xs-12 col-md-7">
        <p class="text-14-b mb-12" style="color:var(--c-primary);text-transform:uppercase;letter-spacing:.05em;">
          {{ global.seo_block_pretitle | mdbr | safe }}
        </p>
        <h2 class="fluid-4-l mb-24" style="font-family:var(--font-display);font-weight:500;font-size:clamp(28px,3.4vw,44px);line-height:1.1;letter-spacing:-0.018em;">
          {{ global.seo_block_title | mdbr | safe }}
        </h2>
        <div class="fluid-9-r mb-16" style="color:var(--c-gray);line-height:1.7;">
          <p>{{ global.seo_block_p1 | mdbr | safe }}</p>
          <p>{{ global.seo_block_p2 | mdbr | safe }}</p>
          <p>{{ global.seo_block_p3 | mdbr | safe }}</p>
        </div>

        <div class="is-flex" style="gap:14px;flex-wrap:wrap;margin-top:24px;">
          <a class="btn btn-primary btn--big" href="/contacto/" data-cta="seoblock_consulta">Reserva tu consulta gratis</a>
          <a class="btn btn-secondary btn--big" href="tel:{{ global.telefono_e164 }}" data-cta="seoblock_tel" style="display:inline-flex;align-items:center;gap:10px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.08 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ global.telefono }}
          </a>
        </div>
      </div>

      <div class="col-xs-12 col-md-5 mb-32 md:mb-0" style="padding-left:24px;">
        <img class="border-20" width="600" height="700" src="/assets/static/images/abogado.jpg" alt="Abogados laboralistas en España — derecho laboral, incapacidad permanente, despidos y Centros Especiales de Empleo" loading="lazy" decoding="async" style="width:100%;border-radius:8px;">
      </div>
    </div>

    {# 4 sub-bloques con H4 keyword-rich estilo el footer superior del competidor #}
    {% if global.seo_block_features and global.seo_block_features.length %}
    <div class="row" style="gap:24px 0;">
      {% for f in global.seo_block_features %}
      <div class="col-xs-12 col-sm-6 col-md-3 mb-24">
        <article style="height:100%;padding:24px;background:var(--bg-light, #F3F2F0);border-radius:10px;border:1px solid #ECEAE6;">
          <h4 style="font-family:var(--font-sans);font-size:16px;font-weight:700;color:var(--c-primary);margin:0 0 10px;line-height:1.3;letter-spacing:0;">{{ f.title }}</h4>
          <p style="font-family:var(--font-sans);font-size:14px;line-height:1.6;color:#5a5a5a;margin:0;">{{ f.text }}</p>
        </article>
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>
