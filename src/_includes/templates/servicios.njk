<!-- servicios.njk -->
<section class="bg-light ptr-120 pbr-120" aria-label="Servicios del despacho">
  <div class="container-global pbr-32">
    <div class="row text-center">
      <div class="col-xs-12">
        <p class="eyebrow mb-16" style="font-family:var(--font-sans);color:var(--c-primary);text-transform:uppercase;letter-spacing:.16em;font-size:12px;font-weight:600;">{{ servicios_pretitle or "Áreas de actuación" }}</p>
        <h2 class="fluid-3-l mb-16" style="font-family:var(--font-display);font-weight:500;font-size:clamp(30px,4vw,52px);line-height:1.08;letter-spacing:-0.02em;max-width:820px;margin:0 auto 20px;">{{ servicios_title or "Nuestros servicios" }}</h2>
        <p class="fluid-8-r" style="font-family:var(--font-sans);color:#5a5a5a;font-size:clamp(16px,1.4vw,18px);line-height:1.6;max-width:680px;margin:0 auto;">
          {{ servicios_subtitle or "Asesoría integral para trabajadores y empresas en derecho laboral, seguridad social y procedimientos de incapacidad. Atención presencial en Sevilla y videoconsulta en toda España." }}
        </p>
      </div>
    </div>
  </div>

  <div class="container-global mx-auto" style="margin-top:48px;">
    <div class="row" style="gap:24px 0;">
      {% for s in global.servicios_list %}
      <article class="col-xs-12 col-sm-6 col-md-4 mb-24">
        <a href="/servicios/{{ s.slug }}/" class="servicio-card" data-cta="servicio_{{ s.slug }}">

          {# Icono inline SVG por slug — minimalista, lineal, color primario #}
          <div class="servicio-card__icon" aria-hidden="true" style="width:48px;height:48px;display:inline-flex;align-items:center;justify-content:center;border-radius:10px;background:rgba(0,0,0,.04);margin-bottom:18px;color:var(--c-primary);">
            {% if s.slug == "despidos" %}
              {# Despidos — documento con X #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m9 13 6 6m0-6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            {% elif s.slug == "incapacidad-permanente" %}
              {# Incapacidad — silla de ruedas / accesibilidad #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="4" r="2" stroke="currentColor" stroke-width="1.6"/><path d="M9 6v8h6l3 6m-9-8 3 4h-3m-3-4a5 5 0 1 0 5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% elif s.slug == "accidentes-laborales" %}
              {# Accidente — casco de seguridad + señal #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 17h18M5 17V11a7 7 0 0 1 14 0v6M9 11V8m6 3V8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="20" r="1.2" fill="currentColor"/></svg>
            {% elif s.slug == "inspecciones-de-trabajo" %}
              {# Inspecciones — lupa #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="m21 21-4.3-4.3M9 11h4m-2-2v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            {% elif s.slug == "centros-especiales-de-empleo" %}
              {# CEE — edificio con corazón #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 21v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            {% elif s.slug == "jubilacion" %}
              {# Jubilación — reloj de arena #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 2h12M6 22h12M6 2v6l6 4 6-4V2M6 22v-6l6-4 6 4v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% elif s.slug == "discapacidad" %}
              {# Discapacidad — accesibilidad #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="5" r="2" stroke="currentColor" stroke-width="1.6"/><path d="M9 8.5v3.5h5.5l2.5 5m-8-5a5 5 0 1 0 4.6 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% elif s.slug == "seguros-vida-invalidez" %}
              {# Seguros — escudo + check #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% else %}
              {# Default — balanza #}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3v18M5 21h14M5 7l7-3 7 3M5 7l-3 7a4 4 0 0 0 8 0L7 7M19 7l3 7a4 4 0 0 1-8 0l5-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% endif %}
          </div>

          <h3>{{ s.title }}</h3>
          <p style="font-family:var(--font-sans);color:var(--c-primary);font-weight:600;font-size:14px;letter-spacing:.005em;margin:0 0 14px;">{{ s.tagline }}</p>
          <p style="font-family:var(--font-sans);color:#5a5a5a;font-size:15px;line-height:1.6;margin:0 0 22px;">{{ s.intro }}</p>
          <span style="display:inline-flex;align-items:center;gap:6px;color:var(--c-primary);font-family:var(--font-sans);font-weight:600;font-size:14px;letter-spacing:.005em;">
            Saber más
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      </article>
      {% endfor %}
    </div>

    <div class="row text-center mt-48">
      <div class="col-xs-12">
        <a class="btn btn-primary btn--big" href="/contacto/" data-cta="servicios_consulta">¿No ves tu caso? Cuéntanoslo gratis</a>
      </div>
    </div>
  </div>
</section>
