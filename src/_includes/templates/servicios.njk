<!-- servicios.njk -->
<section class="bg-light pbr-64 ptr-64" aria-label="Servicios del despacho">
  <div class="container-2 pbr-32">
    <div class="row text-center">
      <div class="col-xs-12">
        <p class="text-14-b mb-8" style="color:var(--c-primary);text-transform:uppercase;letter-spacing:.05em;">{{ servicios_pretitle or "Áreas de actuación" }}</p>
        <h2 class="fluid-5-l mb-16">{{ servicios_title or "Nuestros servicios" }}</h2>
        <p class="fluid-9-r" style="color:var(--c-gray);max-width:760px;margin:0 auto;">
          {{ servicios_subtitle or "Asesoría integral para trabajadores y empresas en derecho laboral, seguridad social y procedimientos de incapacidad. Atención presencial en Sevilla y videoconsulta en toda España." }}
        </p>
      </div>
    </div>
  </div>

  <div class="container-global mx-auto">
    <div class="row" style="gap:24px 0;">
      {% for s in global.servicios_list %}
      <article class="col-xs-12 col-sm-6 col-md-4 mb-24">
        <a href="/servicios/{{ s.slug }}/" class="servicio-card" data-cta="servicio_{{ s.slug }}" style="display:block;height:100%;padding:24px;background:#fff;border:1px solid #eee;border-radius:8px;text-decoration:none;color:inherit;transition:box-shadow .2s,transform .2s,border-color .2s;">
          <h3 class="fluid-9-b mb-8">{{ s.title }}</h3>
          <p class="text-14-r mb-12" style="color:var(--c-primary);font-weight:600;">{{ s.tagline }}</p>
          <p class="fluid-9-r mb-16" style="color:var(--c-gray);">{{ s.intro }}</p>
          <span style="color:var(--c-primary);font-weight:600;">Saber más →</span>
        </a>
      </article>
      {% endfor %}
    </div>

    <div class="row text-center mt-32">
      <div class="col-xs-12">
        <a class="btn btn-primary btn--big" href="/contacto/" data-cta="servicios_consulta">¿No ves tu caso? Cuéntanoslo gratis</a>
      </div>
    </div>
  </div>
</section>
