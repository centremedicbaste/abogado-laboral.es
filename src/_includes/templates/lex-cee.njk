<!-- lex-cee.njk — Bloque navy: Centros Especiales de Empleo / Discapacidad -->
<section class="lex-cee" id="discapacidad" aria-label="Centros Especiales de Empleo y Discapacidad">
  <div class="container-global mx-auto lex-cee__wrap">
    <div class="lex-cee__grid">
      <div class="lex-cee__art">
        <img src="/assets/static/images/centros.jpg" alt="Equipo de un Centro Especial de Empleo" loading="lazy" decoding="async" width="640" height="480"/>
        <span class="lex-cee__art-label">// CEE · empleo protegido</span>
        <span class="lex-cee__art-dot" aria-hidden="true"></span>
      </div>
      <div class="lex-cee__body">
        <p class="lex-eyebrow lex-eyebrow--light">
          <span class="lex-eyebrow__bar" aria-hidden="true"></span>
          Centros Especiales de Empleo
        </p>
        <h2 class="lex-cee__title">Referentes nacionales en empleo protegido.</h2>
        <p class="lex-cee__lead">
          Desde 2010 acompañamos a empresas en su calificación como Centro Especial de Empleo. Hemos tramitado más de <strong>180 calificaciones</strong> y gestionamos cada año cerca de <strong>4 millones de euros</strong> en subvenciones.
        </p>

        <div class="lex-cee__stats">
          <div class="lex-cee__stat">
