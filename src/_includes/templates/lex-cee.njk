          </div>
          <div class="lex-cee__stat">
            <div class="lex-cee__stat-num">Consultoría</div>
            <div class="lex-cee__stat-lbl">Cuota de reserva, enclaves, bonificaciones</div>
          </div>
          <div class="lex-cee__stat">
            <div class="lex-cee__stat-num">Calificación</div>
            <div class="lex-cee__stat-lbl">Toda la tramitación administrativa</div>
          </div>
          <div class="lex-cee__stat">
            <div class="lex-cee__stat-num">Ajustes</div>
            <div class="lex-cee__stat-lbl">Personal y social según normativa</div>
          </div>
        </div>

        <a href="/servicios/centros-especiales-de-empleo/" class="lex-btn lex-btn--accent" data-cta="cee_consulta">
          Hablar con el equipo de CEE
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12 H19 M14 7 L19 12 L14 17" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
        </a>
      </div>
    </div>
  </div>
