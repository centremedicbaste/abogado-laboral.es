<!-- box_img.njk -->
<section class="herohome inview o-hidden bg-hero height-md p-relative" aria-label="Por qué Abogado Laboral">
  <img class="parallax-image" src="/assets/static/images/contact.jpg" alt="" loading="lazy" decoding="async" width="1600" height="900" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.4;" aria-hidden="true">

  <div class="container-global mx-auto" style="position:relative;z-index:1;">
    <div class="row section-x align-middle ptr-64 pbr-64">
      <div class="col-xs-12 col-md-7 front-text">
        <div class="has-light p-24 border-20" style="background:rgba(0,0,0,.55);backdrop-filter:blur(4px);">
          <p class="text-14-b mb-12" style="color:#fff;text-transform:uppercase;letter-spacing:.05em;opacity:.85;">Cobertura nacional</p>
          <p class="fluid-7-r mb-16" style="color:#fff;">{{ box_img_title }}</p>
          <p class="fluid-9-r" style="color:rgba(255,255,255,.85);">{{ box_img_description }}</p>
          <div class="mt-24">
            <a class="btn btn-primary" href="/contacto/" data-cta="boximg_consulta">Reserva tu consulta gratuita</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
