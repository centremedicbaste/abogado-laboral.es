<!-- box_img.njk -->
<section class="parallax-section" aria-label="Por qué Abogado Laboral"
         style="
           position: relative;
           overflow: hidden;
           min-height: 480px;
           background-image: url('/assets/static/images/contact.jpg');
           background-size: cover;
           background-position: center center;
           background-repeat: no-repeat;
           background-color: #1a1a1a;
         ">

  {# Overlay oscuro sobre la imagen — para legibilidad del texto blanco #}
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(90deg, rgba(0,0,0,.65) 0%, rgba(0,0,0,.35) 100%);z-index:1;"></div>

  <div class="container-global" style="position:relative;z-index:2;">
    <div class="row align-middle ptr-64 pbr-64">
      <div class="col-xs-12 col-md-7 front-text">
        <div class="parallax-card" style="
            background: rgba(0,0,0,.55);
            -webkit-backdrop-filter: blur(6px);
            backdrop-filter: blur(6px);
            padding: 32px;
            border-radius: 12px;
            color: #fff;
            border: 1px solid rgba(255,255,255,.08);
          ">
          <p class="text-14-b mb-12" style="color:#fff;text-transform:uppercase;letter-spacing:.05em;opacity:.85;margin:0 0 12px;">
            Cobertura nacional
          </p>
          <p class="fluid-7-r mb-16" style="color:#fff;margin:0 0 16px;font-size:clamp(20px,2vw,26px);line-height:1.35;">
            {{ box_img_title }}
          </p>
          <p class="fluid-9-r" style="color:rgba(255,255,255,.85);margin:0;line-height:1.6;">
            {{ box_img_description }}
          </p>
          <div class="mt-24" style="margin-top:24px;">
            <a class="btn btn-primary" href="/contacto/" data-cta="boximg_consulta" style="background:#fff;color:#1a1a1a;border-color:#fff;">
              Reserva tu consulta gratuita
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Parallax SOLO en desktop — iOS y Android no soportan bien fixed */
  @media (min-width: 992px) and (hover: hover) and (pointer: fine){
    .parallax-section{
      background-attachment: fixed !important;
    }
  }
</style>
