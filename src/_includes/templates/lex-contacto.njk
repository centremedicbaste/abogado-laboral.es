<!-- lex-contacto.njk -->
<!-- lex-contacto.njk — Contacto split (info + form) estilo Lex Garantía -->
<section class="lex-section lex-contacto" id="contacta" aria-label="Contacto">
  <div class="container-global mx-auto">
    <div class="lex-contacto__grid">
      <div class="lex-contacto__info">
        <p class="lex-eyebrow">Cuéntanos tu caso</p>
        <h2 class="lex-section__title">Estudio gratuito de tu caso.</h2>
        <p class="lex-section__intro">Rellena el formulario o llámanos directamente. Un abogado especialista revisará tu caso y te dirá con honestidad si tiene viabilidad — y qué pasos seguir.</p>
        <div class="lex-contacto__channels">
          <a href="tel:{{ global.telefono_e164 }}" class="lex-contacto__channel" data-cta="contacto_tel">
            <span class="lex-contacto__channel-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 4 H9 L11 9 L8 11 C9 14 10 15 13 16 L15 13 L20 15 V19 C20 20 19 21 18 21 C10 21 3 14 3 6 C3 5 4 4 5 4 Z"/></svg>
            </span>
            <span>
              <span class="lex-contacto__channel-label">Teléfono</span>
              <span class="lex-contacto__channel-value">{{ global.telefono }}</span>
            </span>
          </a>
          <a href="mailto:{{ global.email }}" class="lex-contacto__channel" data-cta="contacto_email">
            <span class="lex-contacto__channel-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><rect x="5" y="3" width="14" height="18"/><path d="M8 8 H16 M8 12 H16 M8 16 H13"/></svg>
            </span>
            <span>
              <span class="lex-contacto__channel-label">Email</span>
              <span class="lex-contacto__channel-value">{{ global.email }}</span>
            </span>
          </a>
          <a href="https://wa.me/{{ global.whatsapp }}" target="_blank" rel="noopener" class="lex-contacto__channel" data-cta="contacto_whatsapp">
            <span class="lex-contacto__channel-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5.5 19.5 L6.7 15.6 C6.1 14.5 5.7 13.3 5.7 12 C5.7 8.5 8.5 5.7 12 5.7 C15.5 5.7 18.3 8.5 18.3 12 C18.3 15.5 15.5 18.3 12 18.3 C10.7 18.3 9.5 17.9 8.4 17.3 Z"/><path d="M9.5 9.5 C9.5 11 10 12.4 11 13.4 C12 14.4 13.4 14.9 14.9 14.9 L15.5 13.7 L13.8 13 L13 13.6 C12.5 13.4 12 13.1 11.6 12.7 C11.2 12.3 10.9 11.8 10.7 11.3 L11.3 10.5 L10.6 8.8 Z" fill="currentColor" stroke="none"/></svg>
            </span>
            <span>
              <span class="lex-contacto__channel-label">WhatsApp</span>
              <span class="lex-contacto__channel-value">Escríbenos por WhatsApp</span>
            </span>
          </a>
          <div class="lex-contacto__channel">
            <span class="lex-contacto__channel-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><rect x="4" y="3" width="16" height="18"/><path d="M8 7 H10 M14 7 H16 M8 11 H10 M14 11 H16 M8 15 H10 M14 15 H16"/></svg>
            </span>
            <span>
              <span class="lex-contacto__channel-label">Oficina</span>
              <span class="lex-contacto__channel-value">{{ global.direccion }}, {{ global.codigopostal }} {{ global.ciudad }}</span>
              <span class="lex-contacto__channel-meta">Atendemos en toda España</span>
            </span>
          </div>
        </div>
      </div>
      <form class="lex-contacto__form" name="contacto" method="POST" action="/gracias/" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contacto"/>
        <p hidden><label>No rellenar: <input name="bot-field"/></label></p>
        <div class="lex-form__row lex-form__row--two">
          <input type="text" name="nombre" placeholder="Nombre" autocomplete="given-name" required minlength="2"/>
          <input type="text" name="apellidos" placeholder="Apellidos" autocomplete="family-name"/>
        </div>
        <div class="lex-form__row">
          <input type="email" name="email" placeholder="Email" autocomplete="email"/>
        </div>
        <div class="lex-form__row">
          <input type="tel" name="telefono" placeholder="Teléfono" autocomplete="tel" inputmode="numeric" pattern="[0-9 +()-]{9,15}" required/>
        </div>
        <div class="lex-form__row">
          <select name="tipo_caso">
            <option value="">Tipo de caso</option>
            <option>Despido</option>
            <option>Reclamación de cantidad</option>
            <option>Incapacidad / discapacidad</option>
            <option>Accidente laboral</option>
            <option>CEE</option>
            <option>Inspección de trabajo</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="lex-form__row">
          <textarea name="mensaje" placeholder="Cuéntanos brevemente tu caso" rows="4" maxlength="800"></textarea>
        </div>
        <label class="lex-form__check">
          <input type="checkbox" name="politicas" required/>
          <span>He leído y acepto la <a href="/politica-de-privacidad/" target="_blank" rel="noopener">política de privacidad</a>. Mis datos se tratan con la máxima confidencialidad bajo secreto profesional.</span>
        </label>
        <button type="submit" class="lex-btn lex-btn--primary lex-btn--full" data-cta="form_submit">
          Enviar consulta gratuita
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12 H19 M14 7 L19 12 L14 17" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>
