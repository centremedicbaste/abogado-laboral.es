<!-- contacta_5.njk -->
<section class="front-section pbr-64" aria-label="Dónde encontrarnos">
  <div class="container-global-3 mx-auto">
    <div class="row ptr-64 pb-32">
      <div class="col-xs-12">
        <p class="text-14-b mb-8" style="color:var(--c-primary);text-transform:uppercase;letter-spacing:.05em;">Ven a hablar con nosotros</p>
        <h2 class="fluid-4-m">Dónde encontrarnos</h2>
        <p class="fluid-9-r mt-16" style="color:var(--c-gray);max-width:680px;">
          Sede física en Sevilla y videoconsulta para clientes en cualquier punto de España.
        </p>
      </div>
    </div>
  </div>

  <div class="container-global-3 mx-auto pbr-64">
    <div class="row smmax:reverse">
      <div class="col-xs-12 col-md-6">
        <address style="font-style:normal;" class="fluid-9-r">
          <p class="mb-16"><strong>Visítanos</strong></p>

          <p class="mb-16 is-flex" style="gap:12px;">
            <span aria-hidden="true">📍</span>
            <a target="_blank" rel="noopener" href="{{ global.direction_link }}">{{ global.direction }}</a>
          </p>

          <p class="mb-16 is-flex" style="gap:12px;">
            <span aria-hidden="true">📞</span>
            <a href="tel:{{ global.telefono_e164 }}" data-cta="contacta_5_tel"><strong>{{ global.telefono }}</strong></a>
          </p>

          <p class="mb-16 is-flex" style="gap:12px;">
            <span aria-hidden="true">✉️</span>
            <a href="mailto:{{ global.email }}">{{ global.email }}</a>
          </p>

          <p class="mb-16 is-flex" style="gap:12px;">
            <span aria-hidden="true">💬</span>
            <a href="https://wa.me/{{ global.whatsapp }}" target="_blank" rel="noopener" data-cta="contacta_5_wa">WhatsApp</a>
          </p>

          <p class="mb-16 is-flex" style="gap:12px;">
            <span aria-hidden="true">🕒</span>
            <span>{{ global.horario }}</span>
          </p>
        </address>
      </div>

      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <div class="ar-4-3 border-20 p-relative o-hidden">
          <img src="/assets/static/images/casa.jpg" alt="Despacho de Abogado Laboral en Sevilla" loading="lazy" decoding="async" width="600" height="450" style="width:100%;height:100%;object-fit:cover;">
        </div>
      </div>
    </div>
  </div>

  {% if global.googlemaps_iframe %}
  <div class="container-fluid">
    <div class="row">
      <div class="col-xs-12 height-sm">
        {{ global.googlemaps_iframe | safe }}
      </div>
    </div>
  </div>
  {% endif %}
</section>
