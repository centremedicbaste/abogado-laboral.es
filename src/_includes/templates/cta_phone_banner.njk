<!-- cta_phone_banner.njk -->
{# Banner CTA intermedio — replica del "¿Busca un abogado laboralista en Barcelona?" del competidor.
   Fondo oscuro, teléfono enorme, copy directo. #}
<section class="front-section bg-dark" aria-label="Contacto rápido por teléfono" style="background:linear-gradient(135deg, #1A1A1A 0%, #2C2C2C 100%);color:#fff;">
  <div class="container-global ptr-64 pbr-64">
    <div class="row align-middle">
      <div class="col-xs-12 col-md-7 mb-24 md:mb-0">
        <p class="text-14-b mb-12" style="color:#fff;opacity:.7;text-transform:uppercase;letter-spacing:.16em;font-size:12px;font-weight:600;margin:0 0 14px;">
          {{ global.phone_banner_pretitle or "¿Necesitas un abogado laboralista hoy?" }}
        </p>
        <h2 style="font-family:var(--font-display);font-weight:500;color:#fff;font-size:clamp(28px,3.4vw,42px);line-height:1.1;letter-spacing:-0.018em;margin:0 0 16px;">
          {{ global.phone_banner_title or "Llámanos. Primera consulta gratuita." }}
        </h2>
        <p style="font-family:var(--font-sans);color:rgba(255,255,255,.75);font-size:clamp(15px,1.4vw,17px);line-height:1.6;max-width:560px;margin:0;">
          {{ global.phone_banner_subtitle or "Atendemos clientes en cualquier provincia de España, presencial en Sevilla o por videollamada. Te respondemos en menos de 60 minutos." }}
        </p>
      </div>

      <div class="col-xs-12 col-md-5 text-right" style="text-align:right;">
        <a href="tel:{{ global.telefono_e164 }}" data-cta="phonebanner_tel" style="display:inline-flex;align-items:center;gap:14px;color:#fff;text-decoration:none;background:rgba(255,255,255,.06);padding:18px 28px;border-radius:12px;border:1px solid rgba(255,255,255,.18);transition:background .2s ease,transform .2s ease;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.08 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span style="display:flex;flex-direction:column;align-items:flex-start;line-height:1.1;">
            <span style="font-family:var(--font-sans);font-size:11px;text-transform:uppercase;letter-spacing:.12em;opacity:.65;font-weight:500;margin-bottom:6px;">Llámanos ahora</span>
            <span style="font-family:var(--font-display);font-weight:500;font-size:clamp(26px,3vw,36px);letter-spacing:-0.02em;color:#fff;">{{ global.telefono }}</span>
          </span>
        </a>

        <p style="margin:14px 0 0;font-family:var(--font-sans);font-size:13px;color:rgba(255,255,255,.55);">
          {{ global.horario }}
        </p>
      </div>
    </div>
  </div>
</section>
