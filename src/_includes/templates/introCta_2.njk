<!-- introCta_2.njk -->
<section class="herohome inview o-hidden bg-hero height-auto front-section" aria-label="Bienvenida">
  <div class="video-bg2" aria-hidden="true">
    {% if global.home_image %}
    <picture>
      <source srcset="{{ global.home_image }}" type="image/webp">
      <img src="{{ global.home_image }}" alt="" loading="eager" decoding="async" fetchpriority="high" width="1600" height="900" style="width:100%;height:100%;object-fit:cover;opacity:.18;position:absolute;inset:0;">
    </picture>
    {% endif %}
  </div>

  <div class="container-global mx-auto" style="position:relative;z-index:1;">
    <div class="row section-x align-middle">
      <div class="col-xs-12 col-md-8 align-middle">
        <div class="vertical-wrap ptr-120 pbr-120">
          <p class="hero-eyebrow text-14-b mb-16" style="color:var(--c-accent);text-transform:uppercase;letter-spacing:.08em;">
            Despacho de abogados laboralistas · Cobertura nacional
          </p>

          <h1 class="fluid-3-l mb-24 animate-word" data-delay="0">
            {{ hero_title or "Tu abogado laboralista en toda España" }}
          </h1>

          <p class="fluid-8-r mb-16 animate-word" data-delay="1">
            {{ hero_description or "Especialistas en despidos, incapacidad permanente, accidentes laborales y centros especiales de empleo. Atendemos clientes en cualquier provincia de España." }}
          </p>

          <p class="fluid-9-r mb-32 animate-word" data-delay="2">
            {{ hero_description2 or "Primera consulta gratuita por videollamada o presencial. Te respondemos en menos de 60 minutos." }}
          </p>

          <div class="hero-ctas is-flex" style="gap:16px;flex-wrap:wrap;" data-delay="3">
            <a class="btn btn-primary btn--big" href="/contacto/" data-cta="hero_consulta">
              {{ hero_btn or "Reserva tu consulta gratuita" }}
            </a>
            <a class="btn btn-secondary btn--big" href="tel:{{ global.telefono_e164 }}" data-cta="hero_tel">
              📞 {{ global.telefono }}
            </a>
          </div>

          <ul class="hero-trust list-clear is-flex mt-32" style="gap:24px;flex-wrap:wrap;color:var(--c-gray);font-size:14px;">
            <li>📺 Videoconsulta en cualquier punto de España</li>
            <li>⚖️ Especialistas desde 2009</li>
            <li>📝 Hoja de encargo con honorarios cerrados</li>
            <li>💼 Cuota litis disponible</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
