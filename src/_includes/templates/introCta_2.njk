<!-- introCta_2.njk -->
<section class="herohome inview o-hidden bg-hero front-section" aria-label="Bienvenida" style="position:relative;overflow:hidden;">

  {# Imagen de fondo a pantalla completa con overlay para legibilidad del texto #}
  {% if global.home_image %}
  <div aria-hidden="true" style="position:absolute;inset:0;z-index:0;">
    <img src="{{ global.home_image }}" alt="" loading="eager" decoding="async" fetchpriority="high" width="1920" height="1080" style="width:100%;height:100%;object-fit:cover;display:block;">
    {# Overlay degradado para que el texto tenga contraste sin matar la imagen #}
    <div style="position:absolute;inset:0;background:linear-gradient(100deg, rgba(255,253,250,0.96) 0%, rgba(255,253,250,0.86) 40%, rgba(255,253,250,0.55) 75%, rgba(255,253,250,0.25) 100%);"></div>
  </div>
  {% endif %}

  <div class="container-global" style="position:relative;z-index:1;">
    <div class="row section-x align-middle">
      <div class="col-xs-12 col-md-8 align-middle">
        <div class="vertical-wrap" style="max-width:760px;padding-top:clamp(56px,8vw,110px);padding-bottom:clamp(56px,8vw,110px);">
          <p class="hero-eyebrow animate-word" data-delay="0" style="display:inline-flex;align-items:center;gap:10px;font-family:var(--font-sans);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.16em;color:var(--c-primary);margin-bottom:24px;">
            <span style="display:inline-block;width:32px;height:1px;background:var(--c-primary);"></span>
            Despacho laboralista · Cobertura nacional
          </p>

          <h1 class="fluid-2-l mb-24 animate-word" data-delay="1" style="font-family:var(--font-display);font-weight:500;line-height:1.02;letter-spacing:-0.03em;font-size:clamp(40px,6.4vw,84px);margin-bottom:28px;">
            {{ hero_title or "Tu abogado laboralista en toda España" }}
          </h1>

          <p class="fluid-7-r mb-16 animate-word" data-delay="2" style="font-family:var(--font-sans);font-size:clamp(17px,1.6vw,21px);line-height:1.55;color:#3a3a3a;max-width:620px;margin-bottom:18px;">
            {{ (hero_description or "Especialistas en despidos, incapacidad permanente, accidentes laborales y centros especiales de empleo. Atendemos clientes en cualquier provincia de España.") | mdbr | safe }}
          </p>

          <p class="text-16-r mb-32 animate-word" data-delay="3" style="font-family:var(--font-sans);font-size:15px;line-height:1.6;color:#5a5a5a;max-width:560px;margin-bottom:36px;">
            {{ (hero_description2 or "Primera consulta gratuita por videollamada o presencial. Te respondemos en menos de 60 minutos.") | mdbr | safe }}
          </p>

          <div class="hero-ctas is-flex" style="gap:14px;flex-wrap:wrap;" data-delay="4">
            <a class="btn btn-primary btn--big" href="/contacto/" data-cta="hero_consulta">
              {{ hero_btn or "Reserva tu consulta gratuita" }}
            </a>
            <a class="btn btn-secondary btn--big" href="tel:{{ global.telefono_e164 }}" data-cta="hero_tel" style="display:inline-flex;align-items:center;gap:10px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.08 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ global.telefono }}
            </a>
          </div>

          <ul class="hero-trust list-clear mt-48" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px 32px;margin-top:48px;color:#5a5a5a;font-family:var(--font-sans);font-size:14px;">
            <li style="display:flex;align-items:flex-start;gap:10px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;margin-top:2px;color:var(--c-primary);"><path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Videoconsulta en toda España</span>
            </li>
            <li style="display:flex;align-items:flex-start;gap:10px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;margin-top:2px;color:var(--c-primary);"><path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Especialistas desde 2009</span>
            </li>
            <li style="display:flex;align-items:flex-start;gap:10px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;margin-top:2px;color:var(--c-primary);"><path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Honorarios cerrados por escrito</span>
            </li>
            <li style="display:flex;align-items:flex-start;gap:10px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;margin-top:2px;color:var(--c-primary);"><path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Cuota litis disponible</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
