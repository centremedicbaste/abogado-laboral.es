<!-- credenciales.njk -->
{% if global.credenciales and global.credenciales.length %}
<section class="bg-color ptr-32 pbr-32" aria-label="Colegiaciones y credenciales">
  <div class="container-global">
    <div class="row align-middle">
      <div class="col-xs-12 col-md-3 mb-16">
        <p class="text-12-b" style="color:var(--c-gray);text-transform:uppercase;letter-spacing:.16em;font-size:11px;font-weight:600;margin:0;">
          Colegiaciones · Asociaciones · Tecnología jurídica
        </p>
      </div>

      <div class="col-xs-12 col-md-9">
        <ul class="list-clear" style="display:flex;flex-wrap:wrap;gap:12px 28px;align-items:center;justify-content:flex-start;margin:0;padding:0;">
          {% for c in global.credenciales %}
          <li style="display:inline-flex;align-items:center;gap:10px;color:var(--c-gray);font-family:var(--font-sans);font-size:13px;font-weight:500;letter-spacing:.005em;">
            {% if c.icon == "scale" %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;color:var(--c-primary);"><path d="M12 3v18M5 21h14M5 7l7-3 7 3M5 7l-3 7a4 4 0 0 0 8 0L7 7M19 7l3 7a4 4 0 0 1-8 0l5-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% elif c.icon == "briefcase" %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;color:var(--c-primary);"><rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke="currentColor" stroke-width="1.6"/></svg>
            {% elif c.icon == "shield" %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;color:var(--c-primary);"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            {% elif c.icon == "award" %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;color:var(--c-primary);"><circle cx="12" cy="9" r="6" stroke="currentColor" stroke-width="1.6"/><path d="m8.21 13.89-1.12 7L12 18l4.91 2.89-1.12-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            {% elif c.icon == "lock" %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;color:var(--c-primary);"><rect x="4" y="11" width="16" height="10" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.6"/></svg>
            {% else %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;color:var(--c-primary);"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% endif %}
            <span>{{ c.label }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>
{% endif %}
