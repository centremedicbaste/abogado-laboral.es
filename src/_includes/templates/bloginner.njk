<!-- bloginner.njk -->
---
layout: layout/base.njk
---
{% include "templates/bloghero.njk" %}

<article class="post-article" style="background:#fff;">
  {% set next = collections.post | nextInCollection(page.fileSlug) %}
  {% set previous = collections.post | prevInCollection(page.fileSlug) %}

  <div class="container-global mx-auto" style="padding-top:clamp(48px,7vw,96px);padding-bottom:clamp(48px,7vw,96px);">
    <div class="post-grid">

      {# ── Sidebar TOC + CTA ── #}
      <aside class="post-aside" aria-label="Índice y contacto">
        <div class="post-aside__sticky">
          <div class="post-aside__toc">
            <p class="post-aside__title">En este artículo</p>
            <div class="post-aside__toc-content">
              {{ content | toc | safe }}
            </div>
          </div>

          <div class="post-aside__cta">
            <p class="post-aside__cta-title">¿Necesitas ayuda con tu caso?</p>
            <p class="post-aside__cta-text">Primera consulta gratuita por videollamada o presencial.</p>
            <a class="btn btn-primary btn--full" href="/contacto/" data-cta="post_consulta">Consulta gratis</a>
            <a class="btn btn-secondary btn--full post-aside__tel" href="tel:{{ global.telefono_e164 }}" data-cta="post_tel">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.08 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ global.telefono }}
            </a>
          </div>
        </div>
      </aside>

      {# ── Cuerpo del artículo ── #}
      <div class="post-body innermarkdown">
        {{ content | safe }}

        {# CTA cierre dentro del flujo editorial #}
        <div class="post-end-cta" aria-label="Cierre">
          <p class="post-end-cta__eyebrow">¿Hablamos?</p>
          <p class="post-end-cta__title">Cuéntanos tu caso. La primera consulta es gratis.</p>
          <p class="post-end-cta__text">Atención presencial en Sevilla y videoconsulta en toda España.</p>
          <div class="post-end-cta__actions">
            <a class="btn btn-primary btn--big" href="/contacto/" data-cta="post_end_consulta">Reserva tu consulta</a>
            <a class="btn btn-secondary btn--big" href="https://wa.me/{{ global.whatsapp }}" target="_blank" rel="noopener" data-cta="post_end_wa">Escríbenos por WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if next or previous %}
  <nav class="post-nav" aria-label="Posts adyacentes">
    <div class="container-global mx-auto">
      <div class="post-nav__grid">
        {% if previous %}
        <a href="{{ previous.url }}" class="post-nav__item post-nav__item--prev">
          <span class="post-nav__label">← Anterior</span>
          <span class="post-nav__title">{{ previous.data.title }}</span>
        </a>
        {% else %}<span></span>{% endif %}

        {% if next %}
        <a href="{{ next.url }}" class="post-nav__item post-nav__item--next">
          <span class="post-nav__label">Siguiente →</span>
          <span class="post-nav__title">{{ next.data.title }}</span>
        </a>
        {% else %}<span></span>{% endif %}
      </div>
    </div>
  </nav>
  {% endif %}
</article>

<style>
/* ============================================
   BLOG POST — Layout editorial premium
   ============================================ */
.post-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:48px;
}
@media(min-width:992px){
  .post-grid{
    grid-template-columns:280px minmax(0,1fr);
    gap:80px;
  }
}

/* ── Sidebar ── */
.post-aside{order:2;}
@media(min-width:992px){.post-aside{order:1;}}
.post-aside__sticky{
  position:sticky;
  top:96px;
  display:flex;
  flex-direction:column;
  gap:24px;
}
.post-aside__toc{
  background:#FAF8F5;
  border:1px solid #ECEAE6;
  border-radius:12px;
  padding:24px 22px;
}
.post-aside__title{
  font-family:var(--font-sans);
  font-size:11px;
  font-weight:700;
  letter-spacing:0.18em;
  text-transform:uppercase;
  color:var(--c-primary);
  margin:0 0 16px;
}
.post-aside__toc-content nav,
.post-aside__toc-content > ul,
.post-aside__toc-content .toc{
  font-family:var(--font-sans);
  font-size:14px;
  line-height:1.5;
}
.post-aside__toc-content ul{
  list-style:none;
  padding:0;
  margin:0;
  border-left:1px solid #E0DCD3;
}
.post-aside__toc-content ul ul{
  padding-left:14px;
  margin-top:6px;
  border-left:none;
}
.post-aside__toc-content li{
  margin:0;
  padding:6px 0 6px 14px;
  position:relative;
}
.post-aside__toc-content li::before{
  content:"";
  position:absolute;
  left:-1px;
  top:14px;
  width:8px;
  height:1px;
  background:#E0DCD3;
}
.post-aside__toc-content a{
  color:#5a5a5a;
  text-decoration:none;
  display:block;
  transition:color .15s ease, transform .15s ease;
}
.post-aside__toc-content a:hover{
  color:var(--c-primary);
  transform:translateX(2px);
}

.post-aside__cta{
  background:var(--c-primary,#1A1A1A);
  color:#fff;
  border-radius:12px;
  padding:24px 22px;
}
.post-aside__cta-title{
  font-family:var(--font-display);
  font-weight:500;
  font-size:20px;
  line-height:1.25;
  letter-spacing:-0.01em;
  color:#fff;
  margin:0 0 8px;
}
.post-aside__cta-text{
  font-family:var(--font-sans);
  font-size:13px;
  line-height:1.55;
  color:rgba(255,255,255,.75);
  margin:0 0 18px;
}
.post-aside__cta .btn-primary{
  background:#fff;color:var(--c-primary,#1A1A1A);border-color:#fff;
  margin-bottom:8px;
}
.post-aside__cta .btn-primary:hover{
  background:rgba(255,255,255,.9);color:var(--c-primary,#1A1A1A);
}
.post-aside__cta .btn-secondary{
  color:#fff;border-color:rgba(255,255,255,.5);background:transparent;
}
.post-aside__cta .btn-secondary:hover{background:#fff;color:var(--c-primary,#1A1A1A);border-color:#fff;}
.post-aside__tel{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;font-size:14px;
}

/* ── Cuerpo del artículo ── */
.post-body{
  order:1;
  max-width:760px;
  margin:0;
  font-family:var(--font-sans);
  font-size:18px;
  line-height:1.78;
  color:#2a2a2a;
}
@media(min-width:992px){.post-body{order:2;}}

.post-body > p:first-of-type{
  font-size:21px;
  line-height:1.6;
  color:#1a1a1a;
  font-weight:400;
}

.post-body p{
  margin:0 0 1.4em;
  font-family:var(--font-sans);
}
.post-body strong{color:#1a1a1a;font-weight:600;}

.post-body h2{
  font-family:var(--font-display);
  font-size:clamp(28px,3vw,38px);
  font-weight:500;
  line-height:1.15;
  letter-spacing:-0.022em;
  color:var(--c-primary,#1A1A1A);
  margin:2.4em 0 .6em;
  padding-top:.4em;
  border-top:1px solid #ECEAE6;
}
.post-body h2:first-child{border-top:none;padding-top:0;margin-top:0;}
.post-body h3{
  font-family:var(--font-display);
  font-size:clamp(22px,2.2vw,28px);
  font-weight:500;
  line-height:1.25;
  letter-spacing:-0.012em;
  color:var(--c-primary,#1A1A1A);
  margin:1.8em 0 .5em;
}
.post-body h4{
  font-family:var(--font-sans);
  font-size:18px;
  font-weight:600;
  margin:1.6em 0 .4em;
  color:var(--c-primary,#1A1A1A);
}

.post-body ul, .post-body ol{
  padding-left:1.4em;
  margin:0 0 1.4em;
}
.post-body li{
  margin-bottom:.6em;
  line-height:1.7;
  padding-left:.2em;
}
.post-body ul li::marker{color:var(--c-primary);}
.post-body ol li::marker{color:var(--c-primary);font-weight:600;}

.post-body a:not(.btn){
  color:var(--c-primary);
  text-decoration:underline;
  text-underline-offset:4px;
  text-decoration-thickness:1px;
  text-decoration-color:#bbb;
  transition:text-decoration-color .15s ease;
}
.post-body a:not(.btn):hover{text-decoration-color:var(--c-primary);}

.post-body blockquote{
  margin:2em 0;
  padding:24px 28px;
  border-left:3px solid var(--c-primary,#1A1A1A);
  background:#FAF8F5;
  border-radius:0 10px 10px 0;
  font-family:var(--font-display);
  font-style:italic;
  font-size:20px;
  line-height:1.5;
  color:#1a1a1a;
}
.post-body blockquote p{margin:0;font-family:var(--font-display);font-size:inherit;line-height:inherit;}
.post-body blockquote a{color:var(--c-primary);font-weight:500;text-decoration:underline;text-decoration-color:var(--c-primary);}

.post-body table{
  width:100%;border-collapse:collapse;margin:2em 0;font-size:15px;
  border:1px solid #ECEAE6;border-radius:10px;overflow:hidden;
  font-family:var(--font-sans);
}
.post-body thead th{background:var(--c-primary,#1A1A1A);color:#fff;text-align:left;padding:14px 16px;font-weight:600;font-size:13px;text-transform:uppercase;letter-spacing:.04em;}
.post-body tbody td{padding:13px 16px;border-top:1px solid #ECEAE6;vertical-align:top;}
.post-body tbody tr:nth-child(even){background:#FAF8F5;}

.post-body code{background:#F3F0EB;padding:2px 6px;border-radius:4px;font-size:.92em;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;}
.post-body pre{background:#1a1a1a;color:#e6e6e6;padding:18px 20px;border-radius:10px;overflow-x:auto;font-size:14px;}
.post-body pre code{background:none;padding:0;color:inherit;}
.post-body img{max-width:100%;height:auto;border-radius:12px;margin:2em 0;}
.post-body hr{border:0;border-top:1px solid #ECEAE6;margin:2.5em 0;}

/* anchor-link discreto */
.post-body .anchor-link{opacity:0;margin-right:.35em;text-decoration:none;color:#bbb;font-weight:400;transition:opacity .15s;}
.post-body h2:hover .anchor-link,
.post-body h3:hover .anchor-link,
.post-body h4:hover .anchor-link{opacity:.5;}

/* ── CTA de cierre dentro del cuerpo ── */
.post-end-cta{
  margin:64px 0 0;
  padding:40px 36px;
  background:linear-gradient(135deg,#FAF8F5 0%,#F3F0EB 100%);
  border-radius:16px;
  border:1px solid #ECEAE6;
}
.post-end-cta__eyebrow{
  font-family:var(--font-sans);
  font-size:11px;font-weight:700;
  text-transform:uppercase;letter-spacing:.18em;
  color:var(--c-primary);margin:0 0 12px;
}
.post-end-cta__title{
  font-family:var(--font-display);
  font-weight:500;
  font-size:clamp(22px,2.4vw,30px);
  line-height:1.2;letter-spacing:-0.015em;
  color:var(--c-primary);margin:0 0 12px;
}
.post-end-cta__text{
  font-family:var(--font-sans);
  font-size:16px;line-height:1.6;color:#5a5a5a;margin:0 0 24px;max-width:520px;
}
.post-end-cta__actions{display:flex;gap:12px;flex-wrap:wrap;}

/* ── Navegación entre posts ── */
.post-nav{padding:48px 0 96px;border-top:1px solid #ECEAE6;}
.post-nav__grid{display:grid;grid-template-columns:1fr;gap:16px;}
@media(min-width:768px){.post-nav__grid{grid-template-columns:1fr 1fr;gap:24px;}}
.post-nav__item{
  display:block;
  padding:24px 28px;
  border:1px solid #ECEAE6;
  border-radius:12px;
  text-decoration:none;
  color:var(--c-primary);
  background:#fff;
  transition:border-color .2s ease,transform .2s ease,box-shadow .2s ease;
}
.post-nav__item:hover{border-color:rgba(0,0,0,.18);transform:translateY(-2px);box-shadow:0 12px 28px rgba(0,0,0,.06);}
.post-nav__item--next{text-align:right;}
.post-nav__label{
  display:block;font-family:var(--font-sans);font-size:12px;font-weight:600;
  text-transform:uppercase;letter-spacing:.14em;color:#7a7a7a;margin-bottom:8px;
}
.post-nav__title{
  display:block;font-family:var(--font-display);font-weight:500;
  font-size:18px;line-height:1.3;letter-spacing:-0.01em;color:var(--c-primary);
}
</style>

{% include "templates/contacta_4.njk" %}
