<!-- content_2.njk -->
<section class="bg-color ptr-64" aria-label="Qué ofrecemos">

  <div class="container-global">
    <div class="row">
      <div class="col-xs-12 text-center mb-32">
        <p class="text-14-b mb-8" style="color:var(--c-primary);text-transform:uppercase;letter-spacing:.05em;">
          {{ content_2_subtitle | mdbr | safe }}
        </p>
        <h2 class="fluid-5-l">{{ content_2_title | mdbr | safe }}</h2>
      </div>
    </div>
  </div>

  <div class="container-global pb-64">
    <div class="row ptr-32 pbr-32 smmax:reverse align-middle">
      <div class="col-xs-12 col-sm-6 front-text mb-32 sm:mb-0">
        <img class="border-20" width="600" height="400" src="/assets/static/images/centros.jpg" alt="Centros Especiales de Empleo — calificación y asesoramiento" loading="lazy" decoding="async">
      </div>
      <div class="col-xs-12 col-sm-6 front-text align-middle">
        <div class="wmax-450 mx-auto">
          <div class="fluid-3-b mb-16 c-accent">01</div>
          <h3 class="fluid-5-r mb-24">{{ content_2_title_1 | mdbr | safe }}</h3>
          <p class="fluid-9-r">{{ content_2_description_1 | mdbr | safe }}</p>
          <p class="mt-16"><a class="link-arrow text-14-b" href="/servicios/centros-especiales-de-empleo/">Ver servicio CEE →</a></p>
        </div>
      </div>
    </div>

    <div class="row ptr-32 pbr-32 align-middle">
      <div class="col-xs-12 col-sm-6 front-text align-middle mb-32 sm:mb-0">
        <div class="wmax-450 mx-auto">
          <div class="fluid-3-b mb-16 c-accent">02</div>
          <h3 class="fluid-5-r mb-24">{{ content_2_title_2 | mdbr | safe }}</h3>
          <p class="fluid-9-r">{{ content_2_description_2 | mdbr | safe }}</p>
        </div>
      </div>
      <div class="col-xs-12 col-sm-6 front-text">
        <img width="600" height="400" src="/assets/static/images/png_trans.png" alt="Extranet jurídica con seguimiento del expediente en tiempo real" loading="lazy" decoding="async">
      </div>
    </div>

    <div class="row ptr-32 pbr-32 smmax:reverse align-middle">
      <div class="col-xs-12 col-sm-6 front-text mb-32 sm:mb-0">
        <div class="is-flex is-column" style="gap:16px;">
          <div class="rat-16-9 border-20 o-hidden">
            <div class="rat-content">
              <iframe
                src="https://www.youtube-nocookie.com/embed/oj4BgbaCafE"
                title="Vídeo de YouTube 1 de Abogado Laboral"
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                style="width:100%;height:100%;border:0;"
              ></iframe>
            </div>
          </div>
          <div class="rat-16-9 border-20 o-hidden">
            <div class="rat-content">
              <iframe
                src="https://www.youtube-nocookie.com/embed/lVXh1L2mBoY"
                title="Vídeo de YouTube 2 de Abogado Laboral"
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                style="width:100%;height:100%;border:0;"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xs-12 col-sm-6 front-text align-middle">
        <div class="wmax-450 mx-auto">
          <div class="fluid-3-b mb-16 c-accent">03</div>
          <h3 class="fluid-5-r mb-24">{{ content_2_title_3 | mdbr | safe }}</h3>
          <p class="fluid-9-r mb-24">{{ content_2_description_3 | mdbr | safe }}</p>
          {% if content_2_linkurl_3 %}
          <a class="btn btn-secondary btn--small" target="_blank" rel="noopener" href="{{ content_2_linkurl_3 }}" data-cta="content_youtube">
            {{ content_2_link_3 or "Ver canal" }} →
          </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
