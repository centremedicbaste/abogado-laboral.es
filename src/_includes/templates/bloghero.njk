<!-- bloghero.njk -->
<!-- bloghero.njk — hero editorial para blog (estilo Lex Garantía: navy + accent azul) -->
<section class="bloghero">
  <div class="container-global mx-auto bloghero__wrap">

    <nav class="bloghero__crumbs" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span aria-hidden="true">/</span>
      <a href="/blog/">Blog</a>
      {% if title and page.url != '/blog/' %}
        <span aria-hidden="true">/</span>
        <span class="bloghero__crumbs-current">{{ tags[1] | capitalize if tags and tags.length > 1 else title }}</span>
      {% endif %}
    </nav>

    <div class="bloghero__inner">
      <div class="bloghero__head">
        {% if eyebrow or (tags and tags.length > 1) %}
        <p class="bloghero__eyebrow">
          <span class="bloghero__eyebrow-bar" aria-hidden="true"></span>
          {{ eyebrow or (tags[1] | capitalize) }}
        </p>
        {% endif %}

        <h1 class="bloghero__title">{{ title }}</h1>

        {% if subtitle %}
        <p class="bloghero__subtitle">{{ subtitle }}</p>
        {% endif %}

        <div class="bloghero__meta">
          {% if fecha %}
          <span class="bloghero__meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            {{ fecha }}
          </span>
          {% endif %}
          {% if global.author %}
          <span class="bloghero__meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/></svg>
            {{ global.author }}
          </span>
          {% endif %}
        </div>
      </div>

      {% if image and not noheroimage %}
      <div class="bloghero__image">
        <img width="1200" height="675" src="{{ image }}" alt="{{ imageAlt or title }}" loading="eager" decoding="async" />
        <span class="bloghero__image-dot" aria-hidden="true"></span>
      </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
.bloghero{background:#fff;border-bottom:1px solid #e3e8f3;}
.bloghero__wrap{padding-top:clamp(72px,10vw,140px);padding-bottom:clamp(40px,6vw,72px);}
.bloghero__crumbs{font-family:var(--font-sans);font-size:13px;color:#7180a8;margin-bottom:32px;letter-spacing:.005em;}
.bloghero__crumbs a{color:#7180a8;text-decoration:none;transition:color .15s ease;}
.bloghero__crumbs a:hover{color:var(--c-accent);}
.bloghero__crumbs span[aria-hidden]{margin:0 8px;color:#bcc6da;}
.bloghero__crumbs-current{color:var(--c-primary);font-weight:500;}

.bloghero__inner{display:grid;grid-template-columns:1fr;gap:48px;align-items:center;}
@media(min-width:992px){.bloghero__inner{grid-template-columns:1.05fr .95fr;gap:64px;}}

.bloghero__eyebrow{display:inline-flex;align-items:center;gap:12px;font-family:var(--font-sans);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.22em;color:var(--c-accent);margin:0 0 24px;}
.bloghero__eyebrow-bar{display:inline-block;width:28px;height:1px;background:currentColor;}

.bloghero__title{font-family:var(--font-display);font-weight:500;font-size:clamp(34px,5.5vw,68px);line-height:1.04;letter-spacing:-0.025em;color:var(--c-primary);margin:0 0 24px;max-width:920px;}

.bloghero__subtitle{font-family:var(--font-sans);font-size:clamp(17px,1.6vw,21px);line-height:1.55;color:#5b6b8f;margin:0 0 28px;max-width:760px;font-weight:400;}

.bloghero__meta{display:flex;align-items:center;gap:24px;flex-wrap:wrap;font-family:var(--font-sans);font-size:14px;color:#7180a8;padding-top:24px;border-top:1px solid #e3e8f3;}
.bloghero__meta-item{display:inline-flex;align-items:center;gap:8px;}

.bloghero__image{position:relative;border-radius:18px;overflow:hidden;aspect-ratio:16/9;background:#e6ecf7;border:1px solid #d6deef;}
.bloghero__image img{width:100%;height:100%;object-fit:cover;display:block;}
.bloghero__image-dot{position:absolute;right:14px;top:14px;width:10px;height:10px;border-radius:999px;background:var(--c-accent);}
</style>
