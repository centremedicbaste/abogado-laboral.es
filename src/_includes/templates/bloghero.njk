<!-- bloghero.njk -->
<section class="bg-color">
  <div class="container-global mx-auto ptr-64 pbr-32">
    <nav aria-label="Migas de pan" class="text-14-r mb-24" style="color:var(--c-gray);">
      <a href="/" class="footer-link">Inicio</a> ›
      <a href="/blog/" class="footer-link">Blog</a>
      {% if title %} › <span>{{ title }}</span>{% endif %}
    </nav>
    <div class="row align-middle">
      <div class="col-xs-12 col-md-8 front-text">
        {% if eyebrow %}<p class="text-14-b mb-8" style="color:var(--c-primary);text-transform:uppercase;letter-spacing:.05em;">{{ eyebrow }}</p>{% endif %}
        <h1 class="fluid-3-l mb-16">{{ title }}</h1>
        {% if subtitle %}<p class="fluid-7-r mb-16" style="color:var(--c-gray);">{{ subtitle }}</p>{% endif %}
        {% if fecha %}<p class="text-14-r" style="color:var(--c-gray);">📅 {{ fecha }}</p>{% endif %}
      </div>
      {% if image and not noheroimage %}
      <div class="col-xs-12 col-md-4">
        <img width="600" height="400" src="{{ image }}" alt="{{ imageAlt or title }}" loading="eager" decoding="async">
      </div>
      {% endif %}
    </div>
  </div>
</section>
