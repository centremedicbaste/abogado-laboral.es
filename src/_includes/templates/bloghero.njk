<!-- bloghero.njk -->
<!-- bloghero.njk — hero editorial elegante para blog -->
<section class="bloghero" style="background:#fff;border-bottom:1px solid #ECEAE6;">
  <div class="container-global mx-auto" style="padding-top:clamp(72px,10vw,140px);padding-bottom:clamp(40px,6vw,72px);">

    <nav aria-label="Migas de pan" style="font-family:var(--font-sans);font-size:13px;color:#7a7a7a;margin-bottom:32px;letter-spacing:0.005em;">
      <a href="/" style="color:#7a7a7a;text-decoration:none;">Inicio</a>
      <span style="margin:0 8px;color:#bbb;">/</span>
      <a href="/blog/" style="color:#7a7a7a;text-decoration:none;">Blog</a>
      {% if title and page.url != '/blog/' %}
        <span style="margin:0 8px;color:#bbb;">/</span>
        <span style="color:#1a1a1a;">{{ tags[1] | capitalize if tags and tags.length > 1 else title }}</span>
      {% endif %}
    </nav>

    <div class="bloghero__inner" style="display:grid;grid-template-columns:1fr;gap:48px;align-items:center;">
      <div>
        {% if eyebrow or (tags and tags.length > 1) %}
        <p style="display:inline-flex;align-items:center;gap:10px;font-family:var(--font-sans);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.16em;color:var(--c-primary);margin:0 0 24px;">
          <span style="display:inline-block;width:24px;height:1px;background:currentColor;"></span>
          {{ eyebrow or (tags[1] | capitalize) }}
        </p>
        {% endif %}

        <h1 style="font-family:var(--font-display);font-weight:500;font-size:clamp(32px,5vw,64px);line-height:1.05;letter-spacing:-0.025em;color:var(--c-primary,#1A1A1A);margin:0 0 24px;max-width:920px;">
          {{ title }}
        </h1>

        {% if subtitle %}
        <p style="font-family:var(--font-sans);font-size:clamp(17px,1.6vw,21px);line-height:1.55;color:#5a5a5a;margin:0 0 28px;max-width:760px;font-weight:400;">
          {{ subtitle }}
        </p>
        {% endif %}

        <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;font-family:var(--font-sans);font-size:14px;color:#7a7a7a;">
          {% if fecha %}
          <span style="display:inline-flex;align-items:center;gap:8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            {{ fecha }}
          </span>
          {% endif %}
          {% if global.author %}
          <span style="display:inline-flex;align-items:center;gap:8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/></svg>
            {{ global.author }}
          </span>
          {% endif %}
        </div>
      </div>

      {% if image and not noheroimage %}
      <div style="position:relative;border-radius:16px;overflow:hidden;aspect-ratio:16/9;background:#f3f0eb;">
        <img width="1200" height="675" src="{{ image }}" alt="{{ imageAlt or title }}" loading="eager" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block;">
      </div>
      {% endif %}
    </div>
  </div>
</section>
