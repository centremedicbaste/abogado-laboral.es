---
layout: layout/base.njk
---
{% set title = "Blog de derecho laboral en España" %}
{% set subtitle = "Artículos y guías sobre derecho laboral, despidos, incapacidades, accidentes y centros especiales de empleo." %}
{% set noheroimage = true %}
{% include "templates/bloghero.njk" %}

<section class="front-section bg-light" style="padding-top:clamp(48px,7vw,96px);padding-bottom:clamp(64px,9vw,120px);">
  <div class="container-global mx-auto">
    {% if collections.post and collections.post.length %}
    <ul role="list" class="blog-grid">
      {% for post in collections.post | reverse %}
      <li>
        <a href="{{ post.url }}" class="blog-card">
          {% if post.data.image %}
          <div class="blog-card__media">
            <img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy" decoding="async" width="600" height="338">
          </div>
          {% endif %}
          <div class="blog-card__body">
            {% if post.data.tags and post.data.tags.length > 1 %}
            <span class="blog-card__tag">{{ post.data.tags[1] | capitalize }}</span>
            {% endif %}
            <h2 class="blog-card__title">{{ post.data.title }}</h2>
            {% if post.data.subtitle %}<p class="blog-card__excerpt">{{ post.data.subtitle }}</p>{% endif %}
            <div class="blog-card__meta">
              {% if post.data.fecha %}<span>{{ post.data.fecha }}</span>{% endif %}
              <span class="blog-card__arrow">Leer artículo
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </div>
        </a>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="fluid-7-r" style="color:var(--c-gray);">Próximamente publicaremos artículos sobre derecho laboral.</p>
    {% endif %}
  </div>
</section>

<style>
.blog-grid{
  list-style:none;padding:0;margin:0;
  display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;
}
.blog-card{
  display:flex;flex-direction:column;height:100%;
  background:#fff;border:1px solid #e3e8f3;border-radius:14px;
  text-decoration:none;color:inherit;overflow:hidden;
  transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;
}
.blog-card:hover{
  transform:translateY(-2px);
  box-shadow:0 18px 40px -20px rgba(11,30,79,.2);
  border-color:var(--c-accent);
  opacity:1;
}
.blog-card__media{aspect-ratio:16/9;overflow:hidden;background:#e6ecf7;}
.blog-card__media img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s cubic-bezier(.22,1,.36,1);}
.blog-card:hover .blog-card__media img{transform:scale(1.04);}
.blog-card__body{padding:26px 26px 24px;display:flex;flex-direction:column;flex:1;}
.blog-card__tag{
  display:inline-flex;align-items:center;align-self:flex-start;
  font-family:var(--font-sans);font-size:12px;font-weight:500;
  color:#5b6b8f;
  background:#f5f7fc;border:1px solid #e3e8f3;
  padding:6px 12px;border-radius:999px;margin-bottom:16px;
}
.blog-card__title{
  font-family:var(--font-display);font-weight:500;
  font-size:clamp(22px,1.8vw,26px);line-height:1.2;letter-spacing:-0.015em;
  color:var(--c-primary);margin:0 0 10px;
}
.blog-card__excerpt{
  font-family:var(--font-sans);font-size:14.5px;line-height:1.55;color:#5b6b8f;
  margin:0 0 18px;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;
}
.blog-card__meta{
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  margin-top:auto;padding-top:16px;border-top:1px solid #e3e8f3;
  font-family:var(--font-sans);font-size:13px;color:#7180a8;
}
.blog-card__arrow{
  display:inline-flex;align-items:center;gap:6px;
  color:var(--c-primary);font-weight:500;
  border-bottom:1px solid #e3e8f3;padding-bottom:1px;
  transition:color .15s ease, border-color .15s ease;
}
.blog-card:hover .blog-card__arrow{color:var(--c-accent);border-color:var(--c-accent);}
.blog-card:hover .blog-card__arrow svg{transform:translateX(3px);}
.blog-card__arrow svg{transition:transform .2s ease;}
</style>
