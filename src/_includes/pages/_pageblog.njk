---
layout: layout/base.njk
---
{# Blog index — alineado con el sistema Lex #}

{% set page_title = "Blog de derecho laboral en España" %}
{% set page_subtitle = "Artículos y guías sobre derecho laboral, despidos, incapacidades, accidentes y centros especiales de empleo." %}
{% set eyebrow = "Recursos · Cobertura nacional" %}

{% include "templates/lex-hero-page.njk" %}

<section class="lex-section" style="background:var(--bg-light, #f5f7fc);border-top:1px solid #e3e8f3;">
  <div class="container-global mx-auto">
    {% if collections.post and collections.post.length %}
    <div class="lex-blog__grid">
      {% for post in collections.post | reverse %}
      <article class="lex-blog__card">
        <a href="{{ post.url }}" class="lex-blog__card-link">
          <div class="lex-blog__card-media">
            {% if post.data.image %}
            <img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy" decoding="async" width="600" height="338"/>
            {% else %}
            <span class="lex-blog__card-label">// portada</span>
            {% endif %}
            <span class="lex-blog__card-dot" aria-hidden="true"></span>
          </div>
          {% if post.data.tags and post.data.tags.length > 1 %}
          <span class="lex-pill lex-pill--small">{{ post.data.tags[1] | capitalize }}</span>
          {% endif %}
          <h2 class="lex-blog__card-title">{{ post.data.title }}</h2>
          {% if post.data.subtitle %}
          <p class="lex-blog__card-excerpt">{{ post.data.subtitle }}</p>
          {% endif %}
          <div class="lex-blog__card-meta">
            {% if post.data.fecha %}<span>{{ post.data.fecha }}</span>{% endif %}
            <span class="lex-blog__card-arrow">Leer artículo →</span>
          </div>
        </a>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p style="font-family:var(--font-sans);font-size:17px;color:#5b6b8f;">Próximamente publicaremos artículos sobre derecho laboral.</p>
    {% endif %}
  </div>
</section>

{% include "templates/lex-cta-final.njk" %}
{% include "templates/lex-styles.njk" %}

<style>
/* Excerpt y meta para las cards del índice (extiende lex-blog__card) */
.lex-blog__card-excerpt{
  font-family:var(--font-sans);font-size:14.5px;line-height:1.55;color:#5b6b8f;
  margin:0;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;
}
.lex-blog__card-meta{
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  margin-top:auto;padding-top:14px;border-top:1px solid #e3e8f3;
  font-family:var(--font-sans);font-size:13px;color:#7180a8;
}
.lex-blog__card-arrow{
  color:var(--c-primary);font-weight:500;
  border-bottom:1px solid #e3e8f3;padding-bottom:1px;
  transition:color .15s ease, border-color .15s ease;
}
.lex-blog__card:hover .lex-blog__card-arrow{color:var(--c-accent);border-color:var(--c-accent);}
.lex-blog__card{display:flex;flex-direction:column;height:100%;}
</style>
